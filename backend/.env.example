# ─────────────────────────────────────────────
# Filament — Backend Environment Configuration
# ─────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your API key below
# 3. Run the backend: python main.py
# ─────────────────────────────────────────────

# GOOGLE_API_KEY
# Your free Gemini API key from Google AI Studio.
# Steps to get it:
#   1. Go to https://aistudio.google.com
#   2. Sign in with your Google account
#   3. Click "Get API Key" in the left sidebar
#   4. Click "Create API Key" and copy the key
# The free tier is sufficient — no billing required.
GOOGLE_API_KEY=your_gemini_api_key_here

# AGENT_MODE
# Controls how the backend runs.
# Use "local" for running everything on your machine (recommended for development).
# Use "remote" for the Cloud Run microservices deployment.
AGENT_MODE=local
