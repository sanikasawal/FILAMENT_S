{
  "manifest_version": 3,
  "name": "Filament",
  "version": "1.0.0",
  "description": "Ambient AI workspace co-pilot powered by Gemini Live API",
  "permissions": ["tabs", "storage", "activeTab", "scripting", "identity"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["orb.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Filament"
  },
  "web_accessible_resources": [
    {
      "resources": ["worklet-processor.js", "logo-filament.svg", "logo-filament-vertical.svg"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "toggle-panel": {
      "suggested_key": { "default": "Ctrl+Shift+F", "mac": "Command+Shift+F" },
      "description": "Toggle Filament panel"
    }
  },
  "oauth2": {
    "client_id": "76839905027-9mruei1o58bfots328vsp8a8k5l1suik.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly",
      "https://www.googleapis.com/auth/drive.readonly"
    ]
  }
}
